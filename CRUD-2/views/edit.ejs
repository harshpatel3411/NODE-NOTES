<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="flex items-center justify-center min-h-screen bg-zinc-900 text-white">
    <div class="w-full max-w-md p-6 bg-zinc-800 rounded-lg shadow-lg text-center">
        <div class="nav mb-10 ">
            <a class="text-blue-500" href="/read">Read Users</a>
         <br>
         <br>
        </div>
        <!-- Heading -->
        <h1 class="text-2xl font-semibold mb-4 text-white">Update User</h1>

        <!-- Form -->
        <form action="/update/<%=editedUsers.id%>" method="post" class="flex flex-col gap-4">
            <input class="px-5 py-3 bg-transparent border border-gray-500 rounded-2xl outline-none text-white placeholder-gray-400 focus:ring-2 focus:ring-blue-500" 
                type="text" placeholder="Name" name="name" value="<%=editedUsers.name%>"/>
            <input class="px-5 py-3 bg-transparent border border-gray-500 rounded-2xl outline-none text-white placeholder-gray-400 focus:ring-2 focus:ring-blue-500" 
                type="email" placeholder="Email" name="email"  value="<%=editedUsers.email%>"/>
            <input class="px-5 py-3 bg-transparent border border-gray-500 rounded-2xl outline-none text-white placeholder-gray-400 focus:ring-2 focus:ring-blue-500" 
                type="url" placeholder="Image URL" name="image" value="<%=editedUsers.image%>"/> <!-- Ensure this matches backend -->
            
            <input class="px-5 py-3 bg-yellow-500 text-black rounded-lg text-white font-semibold cursor-pointer transition hover:bg-blue-600 focus:ring-2 focus:ring-blue-300" 
                type="submit" value="Update User"/>
        </form>
        
    </div>
</body>
</html>
