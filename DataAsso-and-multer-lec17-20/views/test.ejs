<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">
      <h3 class="text-3xl m-5">Upload file</h3>
      <form action="/upload" method="post" enctype='multipart/form-data'>
        <input
          class="px-3 m-2 rounded-md py-2 outline-none bg-transparent border-2 border-zinc-800"
          type="file"
          placeholder="file"
          name="image"
        />
        <input
          class="px-5 m-2 rounded-md py-2 bg-blue-500 rounded-md"
          type="submit"
          value="upload file"
        />
      </form>
    </div>
  </body>
</html>
